    <property name="styleSheet">
     <string notr="true">/* یہ پوری ونڈو کا بیک گراؤنڈ رنگ سیٹ کرے گا */
QMainWindow {
    background-color: rgb(170, 170, 0); 
}

/* یہ صرف ٹیبل کے ہیڈر (Date, Day, etc.) کا رنگ بدلے گا */
QHeaderView::section {
    background-color: #2c3e50; /* گہرا نیلا رنگ */
    color: white;               /* سفید لکھائی */
    padding: 4px;
    border: 1px solid #6c7a89;
}

/* یہ باقی ٹیبل کو سفید رکھے گا */
QTableWidget {
    background-color: white;
}</string>
