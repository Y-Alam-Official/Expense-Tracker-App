  <property name="styleSheet">
   <string notr="true">/* صرف ان ناموں والے لیبلز پر اسٹائل لگے گا */
#lblDate, #lblDay, #lblCategory, #lblAmount, #lblDescription {
    color: #2f3640;             /* گہرا سرمئی ٹیکسٹ */
    background: transparent;    /* اس سے مین ونڈو کا کلر خراب نہیں ہوگا */
    border: 1px solid #000000;  /* کالی بارڈر */
    border-radius: 4px;         
    padding: 3px 8px;           
    font-weight: bold;          
}

/* اگر آپ چاہتے ہیں کہ بارڈر کے اندر تھوڑا ہلکا سفید رنگ ہو تو اسے استعمال کریں */
/* ورنہ اوپر والا 'transparent' بہترین ہے */</string>
  </property>
