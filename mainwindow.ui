    <property name="styleSheet">
     <string notr="true">QPushButton {
    background-color: #2e86de; /* خوبصورت نیلے رنگ کا شیڈ */
    color: white;
    border-radius: 10px;
    padding: 8px;
    font-weight: bold;
    font-size: 13px;
    border: 1px solid #2471a3;
}

QPushButton:hover {
    background-color: #54a0ff; /* ماؤس اوپر لانے پر ہلکا نیلا */
}

QPushButton:pressed {
    background-color: #2980b9; /* کلک کرنے پر گہرا نیلا */
}</string>
    </property>
